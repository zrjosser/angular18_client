# NOTA: Angular utiliza archivos de entorno en tiempo de compilación,
# no variables de entorno en tiempo de ejecución.
# Este archivo es solo de referencia documental.
#
# Para cambiar la URL del backend, edita:
#   - src/environments/environment.ts      (desarrollo)
#   - src/environments/environment.prod.ts (producción)
#
# Valor por defecto:
API_URL=http://localhost:3000
